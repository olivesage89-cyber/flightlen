# ---------------------------------------------------------------------------
# FlightLen environment variables
# Copy this file to .env.local and fill in real values when you have them.
# Every value below has a free/no-key fallback baked into the code, so the
# app runs out of the box with nothing filled in.
# ---------------------------------------------------------------------------

# Map tiles -------------------------------------------------------------
# Optional. If unset, FlightLen uses free CARTO raster basemaps (light/dark)
# with no key required. Add a Mapbox token to switch to Mapbox vector tiles.
NEXT_PUBLIC_MAPBOX_TOKEN=

# Aircraft data -----------------------------------------------------------
# Optional. If unset, FlightLen calls the free OpenSky Network REST API
# anonymously (rate-limited). Add OpenSky credentials for higher limits, or
# point FLIGHT_DATA_PROVIDER at a paid feed once you have one.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
FLIGHT_DATA_PROVIDER=opensky

# Weather -------------------------------------------------------------------
# No key required. aviationweather.gov's API is free and public.
AVIATION_WEATHER_BASE_URL=https://aviationweather.gov/api/data

# Supabase (auth + favorites) ------------------------------------------------
# Optional for MVP. Leave blank to run with accounts/favorites disabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Ads -------------------------------------------------------------------------
# Optional. Leave blank to show the reserved ad-slot placeholder only.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
